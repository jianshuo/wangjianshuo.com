Sub VisitAdd (strStarting, strTarget, strIP, strTime)
	If objDic.Exists(strStarting) Then
		objDic(strStarting) = objDic(strStarting) + "||" + strTarget
	Else
		objDic.Add strStarting, strTarget
	End If

	objIPTime(strStarting & strTarget) = objIPTime(strStarting & strTarget)  + strIP + vbCrLf + strTime + vbCrLf

End Sub

Function CheckTag(tag)

	strTagHREF = tag.href

	' fix the problem for www.wangjianshuo.com image viewer
	strTagHREF = Replace(strTagHREF, "../../about/imageviewer.htm", "http://www.wangjianshuo.com/about/imageviewer.htm")

	strTargets = objDic(location.href)

	If strTargets <> "" Then
		arrTargets = Split(strTargets, "||")

		For Each t in arrTargets
			If t = strTagHREF Then
				MarkTag tag, objIPTime(location.href+t)
			End If
		Next
	End If

End Function

iLinks = 0

Sub MarkTag(tag, description)

	tag.className = "nextlink"
	tag.innerHTML = tag.innerHTML + "<span class='linknumber' title='" & description & "'>" & iLinks & "</span>"
	iLinks = iLinks + 1

	For each c in tag.children
		If c.TagName = "IMG" Then
			c.style.borderWidth = "3px"
			c.style.borderColor  = "green"
		End If
	Next
End Sub
For Each taga In document.all.tags("A")
		CheckTag taga
Next
